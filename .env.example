# ═══════════════════════════════════════════════════════════════
# Google Cloud & Gemini API Configuration
# ═══════════════════════════════════════════════════════════════

# Gemini API Key (من Google AI Studio)
# احصل عليه من: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza_YOUR_KEY_HERE

# مفاتيح Gemini متعددة (لتجنب Rate Limiting)
# صيغة: ["KEY1", "KEY2", "KEY3"]
GEMINI_API_KEYS=["AIza_KEY1", "AIza_KEY2", "AIza_KEY3"]

# ═══════════════════════════════════════════════════════════════
# Make.com Webhooks
# ═══════════════════════════════════════════════════════════════

# Webhook لتحديث الأسعار
WEBHOOK_UPDATE_PRICES=https://hook.eu2.make.com/8jia6gc7s1cpkeg6catlrvwck768sbfk

# Webhook للمنتجات الجديدة
WEBHOOK_NEW_PRODUCTS=https://hook.eu2.make.com/xvubj23dmpxu8qzilstd25cnumrwtdxm

# ═══════════════════════════════════════════════════════════════
# بدائل AI (اختياري)
# ═══════════════════════════════════════════════════════════════

# OpenRouter API Key (بديل عند فشل Gemini)
OPENROUTER_API_KEY=sk-or-YOUR_KEY_HERE

# Cohere API Key (بديل آخر)
COHERE_API_KEY=YOUR_COHERE_KEY_HERE

# ═══════════════════════════════════════════════════════════════
# Streamlit Configuration
# ═══════════════════════════════════════════════════════════════

# منفذ التطبيق
PORT=8501

# مسار البيانات الثابتة
DATA_DIR=/data

# تعطيل جمع إحصائيات الاستخدام
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false

# تشغيل بدون واجهة رسومية (للخوادم)
STREAMLIT_SERVER_HEADLESS=true

# حد أقصى لحجم الرسالة (MB)
STREAMLIT_SERVER_MAX_MESSAGE_SIZE=500

# حد أقصى لحجم الملف المرفوع (MB)
STREAMLIT_SERVER_MAX_UPLOAD_SIZE=1000

# ═══════════════════════════════════════════════════════════════
# ملفات البيانات (Base64 أو URL)
# ═══════════════════════════════════════════════════════════════

# للملفات الصغيرة (< 64 KB) - استخدم Base64
CATEGORIES_CSV_B64=
OUR_CATALOG_CSV_B64=
COMPETITORS_JSON_B64=

# للملفات الكبيرة - استخدم URLs
BRANDS_CSV_URL=https://drive.google.com/uc?export=download&id=YOUR_FILE_ID
SALLA_BRANDS_URL=
SALLA_CATEGORIES_URL=

# ═══════════════════════════════════════════════════════════════
# Google Cloud Project Info
# ═══════════════════════════════════════════════════════════════

# معرّف المشروع
GCP_PROJECT_ID=mahwous-smart-pricing-v30

# رقم المشروع
GCP_PROJECT_NUMBER=972549703168

# منطقة Cloud Run (اختياري)
GCP_REGION=us-central1

# ═══════════════════════════════════════════════════════════════
# تطوير محلي (Development)
# ═══════════════════════════════════════════════════════════════

# تفعيل وضع التصحيح
DEBUG=false

# مستوى السجلات (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ═══════════════════════════════════════════════════════════════
# ملاحظات مهمة
# ═══════════════════════════════════════════════════════════════

# 1. لا تضع هذا الملف في GitHub - استخدم .env.example فقط
# 2. انسخ هذا الملف إلى .env وأضف قيمك الفعلية
# 3. لا تشارك مفاتيح API مع أحد
# 4. استخدم متغيرات البيئة في بيئة الإنتاج (Cloud Run)
